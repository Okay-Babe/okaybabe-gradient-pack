# okaybabe-gradient-pack .env.example
#
# Convention:
#   - Variables prefixed VITE_PUBLIC_* are build-time (baked into static assets at build)
#   - Other variables are runtime (read by server-side processes)
#
# This is a static-site pack with no runtime env requirements as of v1.
# This file is intentionally minimal.

# === Analytics (optional) ===
# VITE_PUBLIC_OPENPANEL_CLIENT_ID=<empty> # set in your host's build variables

# === Public site URL ===
# VITE_PUBLIC_SITE_URL=https://okaybabe.com/gradients
